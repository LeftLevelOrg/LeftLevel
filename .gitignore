/FILE_INVENTORY.txt
/README_DEPLOYMENT.md
/RELEASE_NOTES*.md

# Deploy probes
/deploy-probe-*.txt
/deploy-probe-*.html

# Local environment and logs
.env
.env.*
*.log

# OS junk
.DS_Store
Thumbs.db
__MACOSX/

